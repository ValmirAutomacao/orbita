# ─── Supabase ────────────────────────────────────────────────────────────────
# Encontre em: app.supabase.com → Settings → API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>

# ATENÇÃO: service_role bypassa todas as RLS policies (ADR-002).
# NÃO expor no frontend de produção — usar APENAS em edge functions / backend.
# VITE_SUPABASE_SERVICE_ROLE_KEY=<service-role-key>  # descomentado apenas em dev local

# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173
VITE_APP_ENV=development  # development | staging | production

# ─── WhatsApp — Uazapi ────────────────────────────────────────────────────────
# Self-hosted no EasyPanel. Documentação: https://uazapi.dev/docs
#
# VITE_UAZAPI_URL → base URL da instância Uazapi (sem trailing slash).
#   O frontend chama diretamente apenas /instance/connect e /instance/status
#   usando o token recebido do backend via POST /api/v1/whatsapp/provision.
#
# ATENÇÃO: VITE_UAZAPI_INSTANCE_ID e VITE_UAZAPI_TOKEN NÃO devem ser
#   configurados manualmente em produção. As instâncias são criadas e
#   vinculadas automaticamente pelo backend (admintoken server-side).
#   Estes valores são usados APENAS como fallback em dev local sem backend.
VITE_UAZAPI_URL=http://localhost:3000
# VITE_UAZAPI_TOKEN=<token-para-dev-local-sem-backend>  # nunca em produção

# ─── Backend API ──────────────────────────────────────────────────────────────
# URL base da API FastAPI (src/backend). Em produção: domínio do VPS/EasyPanel.
VITE_API_URL=http://localhost:8000/api/v1

# ─── Inteligência Artificial ──────────────────────────────────────────────────
# Claude API — usado no backend FastAPI, não no frontend.
# Registrado aqui apenas para referência do ambiente de desenvolvimento.
# ANTHROPIC_API_KEY=<claude-api-key>   # variável de ambiente do backend (não VITE_)

# ─── OCR ─────────────────────────────────────────────────────────────────────
# Google Vision API — usado no backend FastAPI para leitura de NF-e/NF-PT.
# GOOGLE_VISION_API_KEY=<google-vision-key>   # variável do backend (não VITE_)

