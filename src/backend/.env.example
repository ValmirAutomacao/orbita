# ─── Supabase ────────────────────────────────────────────────────────────────
# Encontre em: app.supabase.com → Settings → API
# service_role bypassa RLS — exclusivo do backend, NUNCA expor no frontend.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service-role-key>

# ─── Uazapi ───────────────────────────────────────────────────────────────────
# Self-hosted no EasyPanel (container Uazapi no mesmo VPS).
# URL interna do container: http://uazapi:3000  (Docker network)
# URL externa (se necessário debug): https://uazapi.seu-dominio.com
# UAZAPI_ADMINTOKEN é a chave mestra — cria instâncias, NUNCA expor ao frontend.
UAZAPI_BASE_URL=http://uazapi:3000
UAZAPI_ADMINTOKEN=<admin-token-do-painel-uazapi>
UAZAPI_SYSTEM_NAME=Pulseo
# URL pública do backend — usada para compor a URL do webhook Uazapi por tenant
API_PUBLIC_URL=https://api.pulseo.pt

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Provider de IA para insights, narrativas e respostas inteligentes (EPIC-10).
# Nunca expor no frontend — todas as chamadas passam pelo backend.
OPENAI_API_KEY=<sua-openai-api-key>
OPENAI_MODEL=gpt-4o          # ou gpt-4o-mini para tasks de menor custo

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Origins permitidos — frontend na Vercel + localhost para dev.
# Em produção: "https://pulseo.pt,https://www.pulseo.pt,https://*.vercel.app"
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ─── Servidor ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENV=development   # development | staging | production

# ─── Celery / Redis (tarefas assíncronas — EPIC-02, EPIC-10) ─────────────────
# Redis como broker Celery — container redis no mesmo EasyPanel.
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
